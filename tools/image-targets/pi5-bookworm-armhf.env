# First-pass image target manifest for Raspberry Pi 5 on Raspberry Pi OS
# Bookworm 32-bit userland. This is build/boot/base handling only; renderer,
# kernel/DRM patches, and bit-perfect output validation are separate work.

PI5_TARGET_DESCRIPTION="Raspberry Pi 5 Bookworm armhf"
TARGET_DESCRIPTION="$PI5_TARGET_DESCRIPTION"
PI5_OUTPUT_SUFFIX="pi5_bookworm_armhf"

# Keep legacy PGenerator runtime helpers that locate the boot/root partitions
# by label working while the Pi 5 runtime port is staged.
PI5_BOOT_LABEL="BOOT_PG"
PI5_ROOT_LABEL="/_PG"

# Bookworm's first-boot user configuration prompt blocks the appliance-style
# headless boot unless a normal login user already exists.
PI5_ADMIN_USER="pi"
PI5_ADMIN_PASSWORD_HASH="${PI5_ROOT_PASSWORD_HASH:-}"
PI5_ADMIN_GROUPS="adm,dialout,cdrom,sudo,audio,video,plugdev,games,users,input,render,netdev,gpio,i2c,spi"
PI5_PGENERATOR_GROUPS="audio,video,input,render,gpio,i2c,spi"
PI5_KEYBOARD_LAYOUT="us"
PI5_LOCALE="C.UTF-8"

# Pi 5 firmware prefers kernel_2712.img when present, but Raspberry Pi OS
# Bookworm armhf images may carry the common 64-bit kernel8.img instead.
PI5_REQUIRED_BOOT_KERNELS="kernel_2712.img kernel8.img"

# Runtime files that differ from the shared UI/calibration overlay live here
# and are applied only when --target pi5-bookworm-armhf is selected.
TARGET_OVERLAY_REL="tools/image-targets/pi5-bookworm-armhf/rootfs"
