# First-pass image target manifest for Raspberry Pi 5 on Raspberry Pi OS
# Bookworm 32-bit userland. This is build/boot/base handling only; renderer,
# kernel/DRM patches, and bit-perfect output validation are separate work.

PI5_TARGET_DESCRIPTION="Raspberry Pi 5 Bookworm armhf"
PI5_OUTPUT_SUFFIX="pi5_bookworm_armhf"

# Keep legacy PGenerator runtime helpers that locate the boot/root partitions
# by label working while the Pi 5 runtime port is staged.
PI5_BOOT_LABEL="BOOT_PG"
PI5_ROOT_LABEL="/_PG"

# Pi 5 Bookworm boot firmware should provide the BCM2712 kernel image.
PI5_REQUIRED_BOOT_KERNEL="kernel_2712.img"
