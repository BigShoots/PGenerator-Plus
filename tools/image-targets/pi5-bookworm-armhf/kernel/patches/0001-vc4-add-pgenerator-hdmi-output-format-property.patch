+static struct vc4_hdmi_connector_state *
+to_vc4_hdmi_connector_state(const struct drm_connector_state *state)
+{
+	return container_of(state, struct vc4_hdmi_connector_state, base);
+}
+
+static const struct drm_prop_enum_list vc4_hdmi_output_format_enum_list[] = {
+	{ VC4_HDMI_PGENERATOR_OUTPUT_RGB444, "RGB444" },
+	{ VC4_HDMI_PGENERATOR_OUTPUT_YCBCR444, "YCBCR444" },
+	{ VC4_HDMI_PGENERATOR_OUTPUT_YCBCR422, "YCBCR422" },
+};
+
+static enum hdmi_colorspace
+vc4_hdmi_pgenerator_output_to_colorspace(unsigned int output_format)
+{
+	switch (output_format) {
+	case VC4_HDMI_PGENERATOR_OUTPUT_YCBCR444:
+		return HDMI_COLORSPACE_YUV444;
+	case VC4_HDMI_PGENERATOR_OUTPUT_YCBCR422:
+		return HDMI_COLORSPACE_YUV422;
+	case VC4_HDMI_PGENERATOR_OUTPUT_RGB444:
+	default:
+		return HDMI_COLORSPACE_RGB;
+	}
+}
+
+static unsigned int
+vc4_hdmi_colorspace_to_pgenerator_output(enum hdmi_colorspace colorspace)
+{
+	switch (colorspace) {
+	case HDMI_COLORSPACE_YUV444:
+		return VC4_HDMI_PGENERATOR_OUTPUT_YCBCR444;
+	case HDMI_COLORSPACE_YUV422:
+		return VC4_HDMI_PGENERATOR_OUTPUT_YCBCR422;
+	case HDMI_COLORSPACE_RGB:
+	default:
+		return VC4_HDMI_PGENERATOR_OUTPUT_RGB444;
+	}
+}
+
+static bool
+vc4_hdmi_sink_supports_output_format(const struct drm_connector *connector,
+				     const struct drm_display_mode *mode,
+				     enum hdmi_colorspace output_format,
+				     unsigned int bpc)
+{
+	const struct drm_display_info *info = &connector->display_info;
+	u8 vic = drm_match_cea_mode(mode);
+
+	if (vic == 1 && bpc != 8)
+		return false;
+
+	if (!info->is_hdmi &&
+	    (output_format != HDMI_COLORSPACE_RGB || bpc != 8))
+		return false;
+
+	switch (output_format) {
+	case HDMI_COLORSPACE_RGB:
+		if (bpc == 10 &&
+		    !(info->edid_hdmi_rgb444_dc_modes & DRM_EDID_HDMI_DC_30))
+			return false;
+		if (bpc == 12 &&
+		    !(info->edid_hdmi_rgb444_dc_modes & DRM_EDID_HDMI_DC_36))
+			return false;
+
+		return true;
+
+	case HDMI_COLORSPACE_YUV444:
+		if (!(info->color_formats & DRM_COLOR_FORMAT_YCBCR444))
+			return false;
+		if (bpc == 10 &&
+		    !(info->edid_hdmi_ycbcr444_dc_modes & DRM_EDID_HDMI_DC_30))
+			return false;
+		if (bpc == 12 &&
+		    !(info->edid_hdmi_ycbcr444_dc_modes & DRM_EDID_HDMI_DC_36))
+			return false;
+
+		return true;
+
+	case HDMI_COLORSPACE_YUV422:
+		if (!(info->color_formats & DRM_COLOR_FORMAT_YCBCR422))
+			return false;
+		if (bpc > 12)
+			return false;
+
+		return true;
+
+	default:
+		return false;
+	}
+}
