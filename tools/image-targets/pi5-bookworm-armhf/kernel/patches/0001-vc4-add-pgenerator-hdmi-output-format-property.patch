+#define VC4_DOVI_INFOFRAME_PAYLOAD_LENGTH	27
+
+static u8 vc4_hdmi_infoframe_checksum(const u8 *buffer, size_t len)
+{
+	u8 sum = 0;
+	size_t i;
+
+	for (i = 0; i < len; i++)
+		sum += buffer[i];
+
+	return 0 - sum;
+}
+
+static void vc4_hdmi_update_dovi_infoframe(struct drm_connector *connector)
+{
+	struct vc4_hdmi_connector_state *vc4_state;
+	struct drm_property_blob *blob;
+	const struct vc4_dovi_output_metadata *dovi;
+	u8 buffer[HDMI_INFOFRAME_HEADER_SIZE +
+		  VC4_DOVI_INFOFRAME_PAYLOAD_LENGTH] = {};
+	u32 oui;
+
+	if (!connector->state)
+		return;
+
+	vc4_state = to_vc4_hdmi_connector_state(connector->state);
+	blob = vc4_state->dovi_output_metadata;
+	if (!blob) {
+		vc4_hdmi_clear_infoframe(connector, HDMI_INFOFRAME_TYPE_VENDOR);
+		return;
+	}
+
+	if (blob->length != sizeof(struct vc4_dovi_output_metadata)) {
+		drm_err(connector->dev,
+			"Ignoring DOVI_OUTPUT_METADATA blob with invalid length %zu\n",
+			blob->length);
+		vc4_hdmi_clear_infoframe(connector, HDMI_INFOFRAME_TYPE_VENDOR);
+		return;
+	}
+
+	dovi = blob->data;
+	if (!dovi->dv_status) {
+		vc4_hdmi_clear_infoframe(connector, HDMI_INFOFRAME_TYPE_VENDOR);
+		return;
+	}
+
+	oui = dovi->oui ? dovi->oui : 0x00d046;
+	buffer[0] = HDMI_INFOFRAME_TYPE_VENDOR;
+	buffer[1] = 1;
+	buffer[2] = VC4_DOVI_INFOFRAME_PAYLOAD_LENGTH;
+	buffer[4] = oui & 0xff;
+	buffer[5] = (oui >> 8) & 0xff;
+	buffer[6] = (oui >> 16) & 0xff;
+	buffer[7] = (dovi->dv_status << 1) | dovi->dv_interface;
+	buffer[8] = dovi->backlight_metadata;
+	buffer[9] = dovi->backlight_max_luminance;
+	buffer[10] = dovi->aux_runmode;
+	buffer[11] = dovi->aux_version;
+	buffer[12] = dovi->aux_debug;
+	buffer[3] = vc4_hdmi_infoframe_checksum(buffer, sizeof(buffer));
+
+	vc4_hdmi_write_infoframe(connector, HDMI_INFOFRAME_TYPE_VENDOR,
+				 buffer, sizeof(buffer));
+}
