+enum vc4_hdmi_pgenerator_output_format {
+	VC4_HDMI_PGENERATOR_OUTPUT_RGB444 = 0,
+	VC4_HDMI_PGENERATOR_OUTPUT_YCBCR444 = 1,
+	VC4_HDMI_PGENERATOR_OUTPUT_YCBCR422 = 2,
+};
+
+struct vc4_hdmi_connector_state {
+	struct drm_connector_state base;
+	struct drm_property_blob *dovi_output_metadata;
+};
+
+struct vc4_dovi_output_metadata {
+	u32 oui;
+	u8 dv_status;
+	u8 dv_interface;
+	u8 backlight_metadata;
+	u8 backlight_max_luminance;
+	u8 aux_runmode;
