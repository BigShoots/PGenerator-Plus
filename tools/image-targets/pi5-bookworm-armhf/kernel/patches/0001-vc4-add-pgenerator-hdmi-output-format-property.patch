+static int vc4_hdmi_connector_set_property(struct drm_connector *connector,
+					   struct drm_connector_state *state,
+					   struct drm_property *property,
+					   uint64_t val)
+{
+	struct vc4_hdmi *vc4_hdmi = connector_to_vc4_hdmi(connector);
+	struct vc4_hdmi_connector_state *vc4_state =
+		to_vc4_hdmi_connector_state(state);
+	bool replaced = false;
+
+	if (property == vc4_hdmi->dovi_output_metadata_property) {
+		return drm_property_replace_blob_from_id(connector->dev,
+				&vc4_state->dovi_output_metadata,
+				val, sizeof(struct vc4_dovi_output_metadata),
+				-1, &replaced);
+	}
+
+	if (property != vc4_hdmi->output_format_property)
+		return -EINVAL;
+
+	state->hdmi.output_format =
+		vc4_hdmi_pgenerator_output_to_colorspace(val);
+
+	return 0;
+}
+
+static int vc4_hdmi_connector_get_property(struct drm_connector *connector,
+					   const struct drm_connector_state *state,
+					   struct drm_property *property,
+					   uint64_t *val)
+{
+	struct vc4_hdmi *vc4_hdmi = connector_to_vc4_hdmi(connector);
+	struct vc4_hdmi_connector_state *vc4_state =
+		to_vc4_hdmi_connector_state(state);
+
+	if (property == vc4_hdmi->dovi_output_metadata_property) {
+		*val = vc4_state->dovi_output_metadata ?
+			vc4_state->dovi_output_metadata->base.id : 0;
+		return 0;
+	}
+
+	if (property != vc4_hdmi->output_format_property)
+		return -EINVAL;
+
+	*val = vc4_hdmi_colorspace_to_pgenerator_output(state->hdmi.output_format);
+
+	return 0;
+}
