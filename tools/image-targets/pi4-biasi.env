# Raspberry Pi 4 target for the legacy Biasi/PGenerator base image.
#
# Shared UI, calibration, meter, and update files come from the top-level
# runtime tree. Pi 4 renderer, display backend, and hardware helpers are
# applied from this target overlay.

TARGET_DESCRIPTION="Raspberry Pi 4 Biasi/PGenerator"
TARGET_OVERLAY_REL="tools/image-targets/pi4-biasi/rootfs"
